{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft": "Information"
    }
  },
  "Storage": {
    "Quota": 1073741824,
    "DataPath": "./data-dev",
    "CleanupIntervalSeconds": 10,
    "StoreDurationDefaultNominalSeconds": 120,
    "StoreDurationDefaultPressureSeconds": 60,
    "StoreDurationTemporaryNominalSeconds": 40,
    "StoreDurationTemporaryPressureSeconds": 20
  }
}
