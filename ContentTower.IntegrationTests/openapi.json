{
  "openapi": "3.1.1",
  "info": {
    "title": "ContentTower | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5135/"
    }
  ],
  "paths": {
    "/Download/download/{cid}": {
      "get": {
        "tags": [
          "Download"
        ],
        "description": "Downloads content as a stream.",
        "parameters": [
          {
            "name": "cid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "$ref": "#/components/schemas/Stream"
                }
              }
            }
          }
        }
      }
    },
    "/Download/metadata/{cid}": {
      "get": {
        "tags": [
          "Download"
        ],
        "description": "Retrieves metadata for content.",
        "parameters": [
          {
            "name": "cid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ContentView"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentView"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentView"
                }
              }
            }
          }
        }
      }
    },
    "/Download/check/{cid}": {
      "get": {
        "tags": [
          "Download"
        ],
        "description": "Checks whether the content exists in this service.",
        "parameters": [
          {
            "name": "cid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "boolean"
                }
              },
              "application/json": {
                "schema": {
                  "type": "boolean"
                }
              },
              "text/json": {
                "schema": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    },
    "/Pin": {
      "post": {
        "tags": [
          "Pin"
        ],
        "description": "Creates a new pin and attaches it to the specified contents.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePinRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePinRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePinRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/CreatePinResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatePinResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatePinResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Pin"
        ],
        "description": "Attached content to or detaches content from the specified pin.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePinRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePinRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePinRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Pin/{pinId}": {
      "get": {
        "tags": [
          "Pin"
        ],
        "description": "Retrieves pin details.",
        "parameters": [
          {
            "name": "pinId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PinView"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PinView"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PinView"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Pin"
        ],
        "description": "Deletes a pin immediately. Not allowed for pins with StoreType 'Permanent'.",
        "parameters": [
          {
            "name": "pinId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Pin/check/{pinId}": {
      "get": {
        "tags": [
          "Pin"
        ],
        "description": "Checks whether the pin exists in this service.",
        "parameters": [
          {
            "name": "pinId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "boolean"
                }
              },
              "application/json": {
                "schema": {
                  "type": "boolean"
                }
              },
              "text/json": {
                "schema": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    },
    "/Pin/force/{pinId}": {
      "delete": {
        "tags": [
          "Pin"
        ],
        "description": "Deletes a pin immediately. Explicit override for pins with StoreType 'Permanent'.",
        "parameters": [
          {
            "name": "pinId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Quota": {
      "get": {
        "tags": [
          "Quota"
        ],
        "description": "Retrieves current quota status information.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/QuotaResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuotaResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuotaResponse"
                }
              }
            }
          }
        }
      }
    },
    "/Quota/config": {
      "get": {
        "tags": [
          "Quota"
        ],
        "description": "Retrieves ContentTower configuration information.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/OptionsView"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OptionsView"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/OptionsView"
                }
              }
            }
          }
        }
      }
    },
    "/Upload": {
      "post": {
        "tags": [
          "Upload"
        ],
        "description": "Stores content in ContentTower. Creates new pins for the content if requested. Attaches existing pins to the content if requested.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UploadRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UploadRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UploadRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ContentView": {
        "type": "object",
        "properties": {
          "cid": {
            "type": "string"
          },
          "pinIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "name": {
            "type": "string"
          },
          "contentType": {
            "type": "string"
          },
          "length": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          }
        }
      },
      "CreatePinRequest": {
        "type": "object",
        "properties": {
          "storeType": {
            "$ref": "#/components/schemas/StoreType"
          },
          "cids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "CreatePinResponse": {
        "type": "object",
        "properties": {
          "pinId": {
            "type": "string"
          }
        }
      },
      "OptionsView": {
        "type": "object",
        "properties": {
          "cleanupIntervalSeconds": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "storeDurationDefaultNominalSeconds": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "storeDurationDefaultPressureSeconds": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "storeDurationTemporaryNominalSeconds": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "storeDurationTemporaryPressureSeconds": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "PinView": {
        "type": "object",
        "properties": {
          "pinId": {
            "type": "string"
          },
          "storeType": {
            "$ref": "#/components/schemas/StoreType"
          },
          "createUtc": {
            "type": "string",
            "format": "date-time"
          },
          "lastActivityUtc": {
            "type": "string",
            "format": "date-time"
          },
          "cids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "QuotaResponse": {
        "type": "object",
        "properties": {
          "quota": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "used": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "state": {
            "$ref": "#/components/schemas/QuotaState"
          }
        }
      },
      "QuotaState": {
        "type": "integer"
      },
      "StoreType": {
        "enum": [
          "Default",
          "Temporary",
          "Permanent"
        ]
      },
      "Stream": {
        "type": "string",
        "format": "binary"
      },
      "UpdatePinRequest": {
        "type": "object",
        "properties": {
          "pinId": {
            "type": "string"
          },
          "addCids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "removeCids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "UploadRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "contentType": {
            "type": "string"
          },
          "data": {
            "type": "string",
            "format": "byte"
          },
          "attachExistingPinIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createNewPins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StoreType"
            }
          }
        }
      },
      "UploadResponse": {
        "type": "object",
        "properties": {
          "cid": {
            "type": "string"
          },
          "newPinIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Download"
    },
    {
      "name": "Pin"
    },
    {
      "name": "Quota"
    },
    {
      "name": "Upload"
    }
  ]
}